{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "lib",
    "outDir": "dist",
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["lib/**/*.ts"]
}
